# Rota 31 Panel - local example. Never commit .env.local with real values.

GOOGLE_APPLICATION_CREDENTIALS="C:/path/to/google-sheets-service-account.json"
SHEET_ID="google-sheet-id"
SHEET_TAB_PENDENTES="APROVACOES_PENDENTES"
SHEET_TAB_REGRAS="CADASTRO_CLIENTES"
SHEET_TAB_CACHE="CACHE_APROVACOES"

N8N_BASE_URL="https://your-n8n.example.com"
N8N_API_KEY="n8n-api-key"
N8N_WF_PRINCIPAL="workflow-id"
N8N_WF_AVISOS="workflow-id"
N8N_WEBHOOK_DECISAO="https://your-n8n.example.com/webhook/processar-decisao-cte"

BSOFT_BASE_URL="https://rota31.e-login.net/services/index.php"
BSOFT_USERNAME=""
BSOFT_PASSWORD=""
BSOFT_BASIC_AUTH=""
BSOFT_HEALTH_PATH=""

FIREBASE_PROJECT_ID="rota-31---backend"
FIREBASE_APPLICATION_CREDENTIALS="C:/path/to/rota31-firebase-adminsdk.json"
FIREBASE_SERVICE_ACCOUNT_JSON=""

PORT=3001
API_KEY="local-api-key"
AUTH_REQUIRED=true
DRY_RUN=true
CORS_ALLOWED_ORIGINS="http://localhost:5173,http://127.0.0.1:5173"

VITE_API_URL="http://localhost:3001"
VITE_API_KEY="local-api-key"
