# SPA rewrite rule for Rota 31 panel
# React Router (BrowserRouter) com basename /rota31/
Options -MultiViews
RewriteEngine On
RewriteBase /rota31/

# Permite que arquivos reais (assets, imagens, fontes) sejam servidos diretamente
RewriteCond %{REQUEST_FILENAME} -f [OR]
RewriteCond %{REQUEST_FILENAME} -d
RewriteRule ^ - [L]

# Qualquer outra rota (ex: /historico, /relatorios, /calendario, /configuracao)
# vai pro index.html da SPA
RewriteRule ^ index.html [L]

# Headers de segurança básicos
<IfModule mod_headers.c>
  Header set X-Frame-Options "SAMEORIGIN"
  Header set X-Content-Type-Options "nosniff"
  Header set Referrer-Policy "strict-origin-when-cross-origin"
</IfModule>

# Cache de assets com hash (Vite gera nomes únicos)
<FilesMatch "\.(js|css|woff|woff2|ttf|otf|eot|png|jpg|jpeg|gif|svg|webp|ico)$">
  Header set Cache-Control "public, max-age=31536000, immutable"
</FilesMatch>

# Index.html sempre fresh (importante pra atualizações da SPA)
<FilesMatch "index\.html$">
  Header set Cache-Control "no-store, no-cache, must-revalidate, max-age=0"
</FilesMatch>
